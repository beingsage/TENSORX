# === EXTERNAL APIs CONFIGURATION ===
MONGODB_URI=

# ========== WEATHER APIs ==========
# OpenWeather: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ========== MAPS APIs ==========
# Mappls India stack: https://about.mappls.com/api/
MAPPLS_ACCESS_TOKEN=

# Ola Maps: https://developer.olamaps.io/docs
OLA_MAPS_API_KEY=
NEXT_PUBLIC_OLA_MAPS_API_KEY=
NEXT_PUBLIC_OLA_MAPS_STYLE_URL=https://api.olamaps.io/tiles/vector/v1/styles/default-light-standard/style.json

# Google Maps Platform: https://cloud.google.com/maps-platform
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HERE Maps: https://developer.here.com
HERE_MAPS_API_KEY=your_here_maps_api_key_here

# MLS API: Contact local MLS data provider
MLS_API_KEY=your_mls_api_key_here
MLS_API_HOST=your_mls_api_host_here

# OpenStreetMap/Nominatim identity (recommended for higher trust with open-data calls)
OSM_APP_NAME=cost-analysis-app
NOMINATIM_EMAIL=


# ========== SATELLITE IMAGERY APIs ==========
# Sentinel Hub: https://www.sentinel-hub.com
SENTINEL_CLIENT_ID=your_sentinel_client_id_here
SENTINEL_CLIENT_SECRET=your_sentinel_client_secret_here

# Planet Labs: https://api.planet.com
PLANET_LABS_API_KEY=your_planet_labs_api_key_here


# ========== NEWS & SENTIMENT APIs ==========
# NewsAPI: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Twitter API (v2): https://developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here

# Reddit API: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here


# ========== ML MODELS API CONFIG ==========
# Real Estate Model Service
REAL_ESTATE_MODEL_URL=http://localhost:5000
REAL_ESTATE_MODEL_PORT=5000

# RealValue Service
REALVALUE_MODEL_URL=http://localhost:5001
REALVALUE_MODEL_PORT=5001

# House Price Estimator Service
HOUSE_PRICE_ESTIMATOR_URL=http://localhost:5002
HOUSE_PRICE_ESTIMATOR_PORT=5002

# GraphSAGE Service
GRAPHSAGE_MODEL_URL=http://localhost:5003
GRAPHSAGE_MODEL_PORT=5003


# ========== DATABASE CONFIG ==========
MONGODB_DB_NAME=cost_analysis

# Optional analytical stores if you still use them elsewhere
DATABASE_URL=postgresql://user:password@localhost:5432/property_valuation
TIMESCALE_URL=postgresql://user:password@localhost:5433/timescale_metrics

# ========== ASSET STORAGE ==========
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ========== REDIS CONFIG ==========
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600


# ========== APPLICATION CONFIG ==========
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NODE_ENV=development
LOG_LEVEL=debug

# Enable specific data sources (comma-separated)
ENABLED_DATA_SOURCES=weather,demographics,maps,listings,satellite,sentiment

# Data caching (in minutes)
WEATHER_CACHE_TTL=60
LISTINGS_CACHE_TTL=1440
SATELLITE_CACHE_TTL=10080
SENTIMENT_CACHE_TTL=480

# Batch processing
BATCH_SIZE=50
MAX_PARALLEL_REQUESTS=10


# ============ RATE LIMITING ============

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============ SECURITY ============

JWT_SECRET=your_jwt_secret_key
CORS_ORIGIN=http://localhost:3000


# Monitoring
DATADOG_API_KEY=your_datadog_key
SENTRY_DSN=your_sentry_dsn


# Feature Flags
ENABLE_3D_MODEL=true
ENABLE_SATELLITE_DATA=true
ENABLE_FEDERATED_LEARNING=true
ENABLE_DISTRESS_TESTING=true
ENABLE_FLIP_SCORING=true

# ============ DEPLOYMENT ============

# AWS (for production deployment)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_ECR_REGISTRY=your_ecr_registry


# AI/ML Services
OPENAI_API_KEY=your_openai_api_key
STABILITY_AI_KEY=your_stability_ai_key
RUNPOD_API_KEY=your_replicate_api_key



# Property portals / aggregator
MAGICBRICKS_SEARCH_URL=http://localhost:8787/magicbricks/search
NINETY_NINE_ACRES_SEARCH_URL=http://localhost:8787/99acres/search
HOUSING_SEARCH_URL=http://localhost:8787/housing/search
LISTINGS_AGGREGATOR_URL=http://localhost:8787/listings/search




# Government Data
MUNICIPAL_API_KEY=your_municipal_api_key
NJDG_API_KEY=your_njdg_court_data_key
LAND_REGISTRY_API_KEY=your_land_registry_key
CENSUS_INDIA_DATA_PATH=./data/census-india
DATAMEET_BOUNDARY_PATH=./data/datameet-boundaries.geojson


# Weather & Climate
WEATHER_API_KEY=your_weather_api_key
FEMA_API_KEY=your_fema_api_key
CPCB_API_KEY=your_cpcb_api_key
